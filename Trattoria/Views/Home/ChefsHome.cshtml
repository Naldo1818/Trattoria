@model Trattoria.ViewModels.ChefsHomeViewModel
@{
    ViewData["Title"] = "Kitchen Dashboard · Trattoria Bella";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --cream: #F5F0E8;
            --warm-white: #FAF7F2;
            --gold: #B8860B;
            --gold-light: #D4A820;
            --brown: #3D2B1F;
            --brown-mid: #6B4226;
            --red: #8B1A1A;
            --text: #2A1F17;
            --text-muted: #7A6558;
            --shadow: 0 8px 24px rgba(0,0,0,0.08);
            --radius: 14px;
        }

        body {
            font-family: 'Jost', sans-serif;
            background: #f2ede6;
            color: var(--text);
            padding: 2rem;
            min-height: 100vh;
        }

        .chef-dashboard {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Header */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .brand {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 600;
            color: var(--brown);
        }

            .brand span {
                color: var(--gold);
            }

        .chef-badge {
            background: var(--brown);
            color: var(--cream);
            padding: 0.4rem 1.4rem;
            border-radius: 40px;
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            font-weight: 400;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 0.5rem 1.4rem;
            border-radius: 40px;
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Jost', sans-serif;
            text-decoration: none;
            display: inline-block;
        }

            .btn-outline:hover {
                background: var(--gold);
                color: white;
            }

        /* Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1.2rem;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: var(--warm-white);
            padding: 1.2rem 1.5rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border-left: 4px solid var(--gold);
        }

            .stat-card .label {
                font-size: 0.65rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--text-muted);
                font-weight: 400;
            }

            .stat-card .value {
                font-family: 'Cormorant Garamond', serif;
                font-size: 2rem;
                font-weight: 400;
                color: var(--brown);
                line-height: 1.2;
            }

            .stat-card .sub {
                font-size: 0.7rem;
                color: var(--text-muted);
                font-weight: 300;
            }

        /* Orders section — full width, no sidebar */
        .orders-section {
            background: var(--warm-white);
            padding: 1.8rem 1.8rem 2rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

            .section-header h3 {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.6rem;
                font-weight: 400;
                color: var(--brown);
            }

            .section-header .sub {
                font-size: 0.7rem;
                color: var(--text-muted);
                letter-spacing: 0.05em;
            }

        /* Order cards grid — 2 columns on wide screens */
        .order-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 1rem;
        }

        @@media (max-width: 760px) {
            .order-list {
                grid-template-columns: 1fr;
            }
        }

        .order-card {
            background: white;
            border-radius: var(--radius);
            padding: 1.2rem 1.4rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            border: 1px solid rgba(184,134,11,0.12);
            transition: 0.15s;
            display: flex;
            flex-direction: column;
            gap: 0.7rem;
        }

            .order-card:hover {
                border-color: var(--gold-light);
            }

            /* Colour the left border by status */
            .order-card.pending {
                border-left: 4px solid #c8a060;
            }

            .order-card.seated {
                border-left: 4px solid #c8a060;
            }

            .order-card.in-progress {
                border-left: 4px solid #d48020;
            }

            .order-card.ready {
                border-left: 4px solid #2a7a2a;
            }

        /* Order head */
        .order-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.4rem;
        }

            .order-head .table-id {
                font-weight: 600;
                font-size: 1rem;
                color: var(--brown);
            }

                .order-head .table-id small {
                    font-weight: 300;
                    color: var(--text-muted);
                    font-size: 0.75rem;
                }

            .order-head .order-time {
                font-size: 0.7rem;
                color: var(--text-muted);
                background: #f0ebe4;
                padding: 0.2rem 0.8rem;
                border-radius: 40px;
            }

        /* Status badge */
        .status-badge {
            font-size: 0.6rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 0.2rem 0.9rem;
            border-radius: 40px;
        }

            .status-badge.pending, .status-badge.seated {
                background: #f0e8dc;
                color: var(--brown-mid);
            }

            .status-badge.in-progress {
                background: #f5e0c8;
                color: #a0672a;
            }

            .status-badge.ready {
                background: #dce8d8;
                color: #1e4a1e;
            }

        /* Order items */
        .order-items {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem 0.7rem;
        }

        .order-item-pill {
            background: #f5f0e8;
            padding: 0.2rem 0.8rem;
            border-radius: 30px;
            font-size: 0.82rem;
            font-weight: 300;
        }

            .order-item-pill .qty {
                font-weight: 600;
                color: var(--brown-mid);
            }

            .order-item-pill .item-type {
                font-size: 0.65rem;
                color: var(--text-muted);
                margin-left: 0.3rem;
            }

        /* Action buttons */
        .order-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.2rem;
        }

            .order-actions button {
                padding: 0.35rem 1.1rem;
                border: none;
                border-radius: 40px;
                font-size: 0.65rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                cursor: pointer;
                font-family: 'Jost', sans-serif;
                transition: 0.2s;
            }

        .btn-start-cooking {
            background: var(--gold);
            color: white;
        }

            .btn-start-cooking:hover {
                background: var(--gold-light);
            }

        .btn-mark-ready {
            background: #2a7a6a;
            color: white;
        }

            .btn-mark-ready:hover {
                background: #1e5a4e;
            }

        .btn-mark-served {
            background: #2a5a2a;
            color: white;
        }

            .btn-mark-served:hover {
                background: #1e421e;
            }

        .btn-cancel-order {
            background: #e8d8d8;
            color: #6a3a3a;
        }

            .btn-cancel-order:hover {
                background: #dcc8c8;
            }

        /* Empty state */
        .empty-state {
            color: var(--text-muted);
            font-weight: 300;
            padding: 2rem 0;
            text-align: center;
            font-style: italic;
            font-size: 1rem;
        }

        /* Toast */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--brown);
            color: var(--cream);
            padding: 0.8rem 1.6rem;
            border-radius: 40px;
            font-size: 0.85rem;
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
            transform: translateX(130%);
            transition: transform 0.35s ease;
            z-index: 999;
        }

            .toast.show {
                transform: translateX(0);
            }
    </style>
</head>
<body>

    <div class="chef-dashboard">

        <!-- HEADER -->
        <header class="dashboard-header">
            <div class="header-left">
                <div class="brand">Trattoria <span>Bella</span></div>
                <span class="chef-badge">🍳 Chef · @Model.ChefName</span>
            </div>
            <div class="header-actions">
                <a asp-action="ChefsHome" class="btn-outline">🔄 Refresh</a>
            </div>
        </header>

        <!-- STATS -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="label">Active Orders</div>
                <div class="value">@Model.ActiveOrdersCount</div>
            </div>
            <div class="stat-card">
                <div class="label">New / Pending</div>
                <div class="value">@Model.PendingCount</div>
            </div>
            <div class="stat-card">
                <div class="label">Cooking</div>
                <div class="value">@Model.CookingCount</div>
            </div>
            <div class="stat-card">
                <div class="label">Ready to Serve</div>
                <div class="value">@Model.ReadyCount</div>
            </div>
            <div class="stat-card">
                <div class="label">Items in Prep</div>
                <div class="value">@Model.TotalItemsInPrep</div>
                <div class="sub">pending + cooking</div>
            </div>
        </div>

        <!-- ORDERS — full width -->
        <section class="orders-section">
            <div class="section-header">
                <h3>🔥 Active Orders</h3>
                <span class="sub">@Model.ActiveOrdersCount order@(Model.ActiveOrdersCount == 1 ? "" : "s")</span>
            </div>

            @if (!Model.Orders.Any())
            {
                <div class="empty-state">No active orders — kitchen is clear. 🍽️</div>
            }
            else
            {
                <div class="order-list">
                    @foreach (var o in Model.Orders)
                    {
                        <div class="order-card @o.StatusCssClass">

                            <!-- Head row -->
                            <div class="order-head">
                                <span class="table-id">
                                    Table @o.TableID
                                    <small>· #@o.OrderID @(string.IsNullOrEmpty(o.TableType) || o.TableType == "—" ? "" : $"· {o.TableType}")</small>
                                </span>
                                <span class="order-time">@o.OrderTime.ToString("HH:mm")</span>
                                <span class="status-badge @o.StatusCssClass">@o.StatusLabel</span>
                            </div>

                            <!-- Items -->
                            @if (o.Lines.Any())
                            {
                                <div class="order-items">
                                    @foreach (var line in o.Lines)
                                    {
                                        <span class="order-item-pill">
                                            <span class="qty">@line.Quantity×</span>
                                            @line.ItemName
                                            <span class="item-type">@line.ItemType</span>
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div style="font-size:0.8rem; color:var(--text-muted); font-style:italic;">No items on this order yet.</div>
                            }

                            <!-- Actions -->
                            <div class="order-actions">

                                @* Pending / Seated → Start Cooking *@
                                @if (o.CanStartCooking)
                                {
                                    <form method="post" asp-action="StartCooking">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@o.OrderID" />
                                        <button type="submit" class="btn-start-cooking">🔪 Start Cooking</button>
                                    </form>
                                }

                                @* In Progress → Mark Ready *@
                                @if (o.CanMarkReady)
                                {
                                    <form method="post" asp-action="MarkOrderReady">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@o.OrderID" />
                                        <button type="submit" class="btn-mark-ready">🔔 Mark Ready</button>
                                    </form>
                                }

                                @* Ready → Collected by Waiter *@
                                @if (o.CanMarkServed)
                                {
                                    <form method="post" asp-action="MarkOrderServed">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@o.OrderID" />
                                        <button type="submit" class="btn-mark-served">🍽️ Collected</button>
                                    </form>
                                }

                                @* Cancel — always available while in kitchen *@
                                @if (!o.CanMarkServed)
                                {
                                    <form method="post" asp-action="CancelKitchenOrder"
                                          onsubmit="return confirm('Cancel order #@o.OrderID?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@o.OrderID" />
                                        <button type="submit" class="btn-cancel-order">✕ Cancel</button>
                                    </form>
                                }

                            </div>
                        </div>
                    }
                </div>
            }
        </section>

    </div>

    <!-- TOAST -->
    <div class="toast" id="toast"></div>

    @if (TempData["ToastMessage"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var t = document.getElementById('toast');
                t.textContent = '@Html.Raw(TempData["ToastMessage"])';
                t.classList.add('show');
                setTimeout(function () { t.classList.remove('show'); }, 3000);
            });
        </script>
    }

</body>
</html>
