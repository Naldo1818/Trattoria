@model Trattoria.ViewModels.BartenderHomeViewModel
@{
    ViewData["Title"] = "Bartender Dashboard · Trattoria Bella";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --cream: #F5F0E8;
            --warm-white: #FAF7F2;
            --gold: #B8860B;
            --gold-light: #D4A820;
            --brown: #3D2B1F;
            --brown-mid: #6B4226;
            --red: #8B1A1A;
            --text: #2A1F17;
            --text-muted: #7A6558;
            --shadow: 0 8px 24px rgba(0,0,0,0.08);
            --radius: 14px;
        }

        body {
            font-family: 'Jost', sans-serif;
            background: #f2ede6;
            color: var(--text);
            padding: 2rem;
            min-height: 100vh;
        }

        .bartender-dashboard {
            max-width: 1440px;
            margin: 0 auto;
        }

        /* ----- HEADER ----- */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .brand {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 600;
            color: var(--brown);
        }

            .brand span {
                color: var(--gold);
            }

        .bartender-badge {
            background: var(--brown);
            color: var(--cream);
            padding: 0.4rem 1.4rem;
            border-radius: 40px;
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            font-weight: 400;
        }

        .header-actions {
            display: flex;
            gap: 0.8rem;
            align-items: center;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 0.5rem 1.4rem;
            border-radius: 40px;
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Jost', sans-serif;
            text-decoration: none;
            display: inline-block;
        }

            .btn-outline:hover {
                background: var(--gold);
                color: white;
            }

        /* ----- STATS ROW (bar metrics) ----- */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1.2rem;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: var(--warm-white);
            padding: 1.2rem 1.5rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border-left: 4px solid var(--gold);
        }

            .stat-card .label {
                font-size: 0.65rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--text-muted);
                font-weight: 400;
            }

            .stat-card .value {
                font-family: 'Cormorant Garamond', serif;
                font-size: 2rem;
                font-weight: 400;
                color: var(--brown);
                line-height: 1.2;
            }

            .stat-card .sub {
                font-size: 0.7rem;
                color: var(--text-muted);
                font-weight: 300;
            }

        /* ----- DRINK ORDERS (bar view) ----- */
        .orders-section {
            background: var(--warm-white);
            padding: 1.8rem 1.8rem 2rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

            .section-header h3 {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.6rem;
                font-weight: 400;
                color: var(--brown);
            }

            .section-header .sub {
                font-size: 0.7rem;
                color: var(--text-muted);
                letter-spacing: 0.05em;
            }

        .order-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .order-card {
            background: white;
            border-radius: var(--radius);
            padding: 1.2rem 1.4rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            border: 1px solid rgba(184,134,11,0.12);
            transition: 0.15s;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

            .order-card:hover {
                border-color: var(--gold-light);
            }

        .order-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

            .order-head .table-id {
                font-weight: 600;
                font-size: 1rem;
                color: var(--brown);
            }

                .order-head .table-id small {
                    font-weight: 300;
                    color: var(--text-muted);
                    font-size: 0.75rem;
                }

            .order-head .time {
                font-size: 0.7rem;
                color: var(--text-muted);
                background: #f0ebe4;
                padding: 0.2rem 0.8rem;
                border-radius: 40px;
            }

            .order-head .status-badge {
                font-size: 0.6rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                padding: 0.2rem 0.9rem;
                border-radius: 40px;
                background: #f0e8dc;
                color: var(--brown-mid);
            }

                .order-head .status-badge.ready {
                    background: #dce8d8;
                    color: #1e4a1e;
                }

                .order-head .status-badge.in-progress {
                    background: #f5e0c8;
                    color: #a0672a;
                }

                .order-head .status-badge.pending {
                    background: #f0d8d8;
                    color: #8b1a1a;
                }

                .order-head .status-badge.served {
                    background: #d8e8d8;
                    color: #1e4a1e;
                }

        .order-items {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem 0.8rem;
            font-size: 0.85rem;
            color: var(--text);
        }

            .order-items .item {
                background: #f5f0e8;
                padding: 0.15rem 0.7rem;
                border-radius: 30px;
                font-weight: 300;
            }

                .order-items .item .qty {
                    font-weight: 500;
                    color: var(--brown-mid);
                }

                .order-items .item.drink {
                    background: #e8eef0;
                    border-left: 2px solid var(--gold-light);
                }

        .order-actions {
            display: flex;
            gap: 0.6rem;
            margin-top: 0.2rem;
            flex-wrap: wrap;
        }

            .order-actions button {
                padding: 0.3rem 1.2rem;
                border: none;
                border-radius: 40px;
                font-size: 0.65rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                cursor: pointer;
                font-family: 'Jost', sans-serif;
                transition: 0.2s;
            }

        .btn-mix {
            background: var(--gold);
            color: white;
        }

            .btn-mix:hover {
                background: var(--gold-light);
            }

        .btn-serve-drink {
            background: #2a5a2a;
            color: white;
        }

            .btn-serve-drink:hover {
                background: #1e421e;
            }

        .btn-done-drink {
            background: #ccc;
            color: #333;
        }

            .btn-done-drink:hover {
                background: #bbb;
            }

        .btn-cancel-drink {
            background: #e8d8d8;
            color: #6a3a3a;
        }

            .btn-cancel-drink:hover {
                background: #dcc8c8;
            }

        /* Empty state */
        .empty-state {
            color: var(--text-muted);
            font-weight: 300;
            padding: 2rem 0;
            text-align: center;
            font-style: italic;
        }

        /* ----- TOAST ----- */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--brown);
            color: var(--cream);
            padding: 0.8rem 1.6rem;
            border-radius: 40px;
            font-size: 0.85rem;
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
            transform: translateX(130%);
            transition: transform 0.35s ease;
            z-index: 999;
        }

            .toast.show {
                transform: translateX(0);
            }

        /* responsive */
        @@media (max-width: 768px) {
            body {
                padding: 1rem;
            }

            .stats-row {
                grid-template-columns: 1fr 1fr;
            }

            .order-head {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>

    <div class="bartender-dashboard">

        <!-- HEADER -->
        <header class="dashboard-header">
            <div class="header-left">
                <div class="brand">Trattoria <span>Bella</span></div>
                <span class="bartender-badge">🍸 Bartender · @Model.BartenderName</span>
            </div>
            <div class="header-actions">
                <a asp-action="BartenderHome" class="btn-outline">🔄 Refresh</a>
            </div>
        </header>

        <!-- STATS -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="label">Active drink orders</div>
                <div class="value">@Model.ActiveDrinkOrders</div>
            </div>
            <div class="stat-card">
                <div class="label">Mixing</div>
                <div class="value">@Model.MixingCount</div>
            </div>
            <div class="stat-card">
                <div class="label">Ready to serve</div>
                <div class="value">@Model.ReadyCount</div>
            </div>
            <div class="stat-card">
                <div class="label">Total Tables</div>
                <div class="value">@Model.TotalTables</div>
            </div>
        </div>

        <!-- DRINK ORDERS -->
        <section class="orders-section">
            <div class="section-header">
                <h3>🍹 Drink Orders</h3>
                <span class="sub">@Model.ActiveDrinkOrders orders</span>
            </div>

            @if (!Model.DrinkOrders.Any())
            {
                <div class="empty-state">🍸 No drink orders waiting. All caught up!</div>
            }
            else
            {
                <div class="order-list">
                    @foreach (var order in Model.DrinkOrders)
                    {
                        <div class="order-card">
                            <div class="order-head">
                                <span class="table-id">
                                    Table @order.TableID
                                    <small>· @order.TableType</small>
                                </span>
                                <span class="time">@order.TimeDisplay</span>
                                <span class="status-badge @order.StatusCssClass">
                                    @order.StatusLabel
                                </span>
                            </div>
                            <div class="order-items">
                                @foreach (var item in order.Items)
                                {
                                    <span class="item drink">
                                        <span class="qty">@item.Quantity×</span> @item.ItemName
                                    </span>
                                }
                            </div>
                            <div class="order-actions">
                                @if (order.CanStartMixing)
                                {
                                    <form method="post" asp-action="StartMixingDrinkOrder">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@order.OrderID" />
                                        <button type="submit" class="btn-mix">🥄 Start mixing</button>
                                    </form>
                                }
                                @if (order.CanMarkReady)
                                {
                                    <form method="post" asp-action="MarkDrinkOrderReady">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@order.OrderID" />
                                        <button type="submit" class="btn-serve-drink">✅ Mark ready</button>
                                    </form>
                                }
                                @if (order.CanServe)
                                {
                                    <form method="post" asp-action="ServeDrinkOrder">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@order.OrderID" />
                                        <button type="submit" class="btn-done-drink">🍸 Served</button>
                                    </form>
                                }
                                @if (order.CanCancel)
                                {
                                    <form method="post" asp-action="CancelDrinkOrder"
                                          onsubmit="return confirm('Cancel drink order #@order.OrderID? This will remove all drink items from the order.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderID" value="@order.OrderID" />
                                        <button type="submit" class="btn-cancel-drink">✕ Cancel</button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

    </div>

    <!-- TOAST -->
    <div class="toast" id="toast"></div>

    @if (TempData["ToastMessage"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var t = document.getElementById('toast');
                t.textContent = '@Html.Raw(TempData["ToastMessage"])';
                t.classList.add('show');
                setTimeout(function () { t.classList.remove('show'); }, 3000);
            });
        </script>
    }

</body>
</html>