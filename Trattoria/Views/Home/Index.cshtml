<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trattoria Bella — Authentic Italian Cuisine</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
          --cream: #F5F0E8;
          --warm-white: #FAF7F2;
          --gold: #B8860B;
          --gold-light: #D4A820;
          --brown: #3D2B1F;
          --brown-mid: #6B4226;
          --red: #8B1A1A;
          --text: #2A1F17;
          --text-muted: #7A6558;
        }

        html { scroll-behavior: smooth; }

        body {
          font-family: 'Jost', sans-serif;
          background: var(--warm-white);
          color: var(--text);
          overflow-x: hidden;
        }

        /* NAV */
        nav {
          position: fixed; top: 0; left: 0; right: 0; z-index: 100;
          display: flex; justify-content: space-between; align-items: center;
          padding: 1.5rem 4rem;
          background: rgba(250, 247, 242, 0.92);
          backdrop-filter: blur(8px);
          border-bottom: 1px solid rgba(184, 134, 11, 0.2);
          transition: padding 0.3s;
        }

        .nav-logo {
          font-family: 'Cormorant Garamond', serif;
          font-size: 1.6rem;
          font-weight: 600;
          color: var(--brown);
          letter-spacing: 0.04em;
        }

        .nav-logo span { color: var(--gold); }

        .nav-links {
          display: flex; gap: 2.5rem; list-style: none;
        }

        .nav-links a {
          font-size: 0.78rem;
          letter-spacing: 0.14em;
          text-transform: uppercase;
          color: var(--text-muted);
          text-decoration: none;
          transition: color 0.2s;
        }

        .nav-links a:hover { color: var(--gold); }

        .nav-reserve {
          font-size: 0.75rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          border: 1px solid var(--gold);
          color: var(--gold);
          padding: 0.55rem 1.4rem;
          text-decoration: none;
          transition: all 0.25s;
        }

        .nav-reserve:hover {
          background: var(--gold);
          color: white;
        }

        /* HERO */
        .hero {
          min-height: 100vh;
          display: grid;
          grid-template-columns: 1fr 1fr;
          padding-top: 80px;
        }

        .hero-text {
          display: flex; flex-direction: column; justify-content: center;
          padding: 6rem 4rem 6rem 6rem;
        }

        .hero-tag {
          font-size: 0.72rem;
          letter-spacing: 0.2em;
          text-transform: uppercase;
          color: var(--gold);
          margin-bottom: 1.5rem;
        }

        .hero-title {
          font-family: 'Cormorant Garamond', serif;
          font-size: clamp(3rem, 5vw, 5rem);
          font-weight: 300;
          line-height: 1.1;
          color: var(--brown);
          margin-bottom: 2rem;
        }

        .hero-title em {
          font-style: italic;
          color: var(--red);
        }

        .hero-desc {
          font-size: 1rem;
          line-height: 1.8;
          color: var(--text-muted);
          max-width: 420px;
          margin-bottom: 2.5rem;
          font-weight: 300;
        }

        .hero-actions { display: flex; gap: 1rem; align-items: center; }

        .btn-primary {
          background: var(--red);
          color: white;
          padding: 0.9rem 2.2rem;
          text-decoration: none;
          font-size: 0.78rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          transition: background 0.25s;
        }

        .btn-primary:hover { background: var(--brown); }

        .btn-secondary {
          color: var(--text-muted);
          font-size: 0.78rem;
          letter-spacing: 0.1em;
          text-decoration: none;
          display: flex; align-items: center; gap: 0.5rem;
          transition: color 0.2s;
        }

        .btn-secondary:hover { color: var(--gold); }

        .hero-image {
          background: var(--cream);
          position: relative;
          overflow: hidden;
        }

        .hero-image-inner {
          width: 100%; height: 100%;
          background: #E8E0D0;
          display: flex; align-items: center; justify-content: center;
          overflow: hidden;
        }

        .hero-photo {
          width: 100%; height: 100%;
          object-fit: cover;
          object-position: center;
          transition: transform 0.6s ease;
        }
        .hero-photo:hover { transform: scale(1.03); }

        .hero-badge {
          position: absolute; bottom: 3rem; left: -1.5rem;
          background: var(--brown);
          color: var(--cream);
          padding: 1.2rem 2rem;
          font-family: 'Cormorant Garamond', serif;
          font-size: 0.9rem;
          font-style: italic;
          font-weight: 300;
          letter-spacing: 0.05em;
          box-shadow: 4px 4px 0 rgba(184,134,11,0.3);
        }

        /* DIVIDER */
        .divider {
          display: flex; align-items: center; gap: 1.5rem;
          padding: 0 6rem;
          margin: 1rem 0;
        }
        .divider-line { flex: 1; height: 1px; background: rgba(184,134,11,0.25); }
        .divider-icon { color: var(--gold); font-size: 1rem; }

        /* ABOUT STRIP */
        .about-strip {
          background: var(--brown);
          color: var(--cream);
          padding: 4rem 6rem;
          display: grid;
          grid-template-columns: 1fr 1fr 1fr;
          gap: 3rem;
          align-items: start;
        }

        .about-stat { text-align: center; }

        .about-stat-num {
          font-family: 'Cormorant Garamond', serif;
          font-size: 3.5rem;
          font-weight: 300;
          color: var(--gold-light);
          display: block;
          line-height: 1;
          margin-bottom: 0.4rem;
        }

        .about-stat-label {
          font-size: 0.75rem;
          letter-spacing: 0.15em;
          text-transform: uppercase;
          color: rgba(245,240,232,0.6);
        }

        /* MENU SECTION */
        .section { padding: 6rem; }

        .section-header {
          display: grid;
          grid-template-columns: 1fr auto 1fr;
          align-items: center;
          gap: 2rem;
          margin-bottom: 4rem;
        }

        .section-header-line { height: 1px; background: rgba(184,134,11,0.3); }

        .section-header-center { text-align: center; }

        .section-tag {
          font-size: 0.7rem;
          letter-spacing: 0.2em;
          text-transform: uppercase;
          color: var(--gold);
          margin-bottom: 0.5rem;
        }

        .section-title {
          font-family: 'Cormorant Garamond', serif;
          font-size: 2.6rem;
          font-weight: 300;
          color: var(--brown);
          line-height: 1.2;
        }

        .menu-tabs {
          display: flex; justify-content: center; gap: 0;
          margin-bottom: 3rem;
          border-bottom: 1px solid rgba(184,134,11,0.2);
        }

        .menu-tab {
          padding: 0.7rem 2rem;
          font-size: 0.75rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          border: none;
          background: none;
          cursor: pointer;
          color: var(--text-muted);
          border-bottom: 2px solid transparent;
          margin-bottom: -1px;
          transition: all 0.2s;
          font-family: 'Jost', sans-serif;
        }

        .menu-tab.active {
          color: var(--red);
          border-bottom-color: var(--red);
        }

        .menu-tab:hover { color: var(--brown); }

        .menu-grid {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0;
        }

        .menu-item {
          padding: 1.4rem 2rem;
          border-bottom: 1px solid rgba(184,134,11,0.12);
          display: flex;
          justify-content: space-between;
          align-items: start;
          gap: 1.5rem;
          transition: background 0.2s;
        }

        .menu-item:hover { background: rgba(245,240,232,0.6); }

        .menu-item-info { flex: 1; }

        .menu-item-name {
          font-family: 'Cormorant Garamond', serif;
          font-size: 1.15rem;
          font-weight: 600;
          color: var(--brown);
          margin-bottom: 0.25rem;
        }

        .menu-item-desc {
          font-size: 0.8rem;
          color: var(--text-muted);
          line-height: 1.5;
          font-weight: 300;
        }

        .menu-item-price {
          font-family: 'Cormorant Garamond', serif;
          font-size: 1rem;
          color: var(--gold);
          font-weight: 600;
          white-space: nowrap;
          padding-top: 0.1rem;
        }

        .menu-category {
          display: none;
        }

        .menu-category.active { display: contents; }

        /* SIGNATURE DISH */
        .signature {
          background: var(--cream);
          padding: 6rem;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 5rem;
          align-items: center;
        }

        .signature-visual {
          background: var(--warm-white);
          aspect-ratio: 1;
          display: flex; align-items: center; justify-content: center;
          position: relative;
        }

        .signature-visual::before {
          content: '';
          position: absolute; inset: 1.5rem;
          border: 1px solid rgba(184,134,11,0.25);
        }

        .signature-tag {
          font-size: 0.7rem;
          letter-spacing: 0.2em;
          text-transform: uppercase;
          color: var(--gold);
          margin-bottom: 1rem;
        }

        .signature-title {
          font-family: 'Cormorant Garamond', serif;
          font-size: 2.8rem;
          font-weight: 300;
          color: var(--brown);
          line-height: 1.15;
          margin-bottom: 1.5rem;
        }

        .signature-desc {
          font-size: 0.95rem;
          line-height: 1.85;
          color: var(--text-muted);
          margin-bottom: 2rem;
          font-weight: 300;
        }

        .ingredients {
          display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;
        }

        .ingredient-tag {
          font-size: 0.7rem;
          letter-spacing: 0.1em;
          text-transform: uppercase;
          color: var(--brown-mid);
          border: 1px solid rgba(107,66,38,0.3);
          padding: 0.35rem 0.9rem;
        }

        /* TESTIMONIALS */
        .testimonials {
          padding: 6rem;
          background: var(--warm-white);
          text-align: center;
        }

        .quotes-grid {
          display: grid;
          grid-template-columns: 1fr 1fr 1fr;
          gap: 2rem;
          margin-top: 3rem;
        }

        .quote-card {
          background: var(--cream);
          padding: 2.5rem 2rem;
          position: relative;
          text-align: left;
        }

        .quote-mark {
          font-family: 'Cormorant Garamond', serif;
          font-size: 5rem;
          line-height: 1;
          color: rgba(184,134,11,0.2);
          position: absolute;
          top: 0.5rem; left: 1.2rem;
          font-weight: 300;
        }

        .quote-text {
          font-family: 'Cormorant Garamond', serif;
          font-size: 1.05rem;
          font-style: italic;
          font-weight: 300;
          line-height: 1.75;
          color: var(--brown);
          margin-top: 1.5rem;
          margin-bottom: 1.5rem;
        }

        .quote-author {
          font-size: 0.72rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color: var(--gold);
        }

        .stars {
          display: flex; gap: 3px; margin-bottom: 0.5rem;
        }

        .star { color: var(--gold-light); font-size: 0.9rem; }

        /* RESERVATION */
        .reservation {
          background: var(--brown);
          padding: 7rem 6rem;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 6rem;
          align-items: center;
          color: var(--cream);
        }

        .reservation-title {
          font-family: 'Cormorant Garamond', serif;
          font-size: 3rem;
          font-weight: 300;
          color: var(--cream);
          line-height: 1.15;
          margin-bottom: 1rem;
        }

        .reservation-desc {
          font-size: 0.9rem;
          line-height: 1.8;
          color: rgba(245,240,232,0.65);
          margin-bottom: 2rem;
          font-weight: 300;
        }

        .info-block { margin-bottom: 1.2rem; }

        .info-label {
          font-size: 0.65rem;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          color: var(--gold-light);
          margin-bottom: 0.25rem;
        }

        .info-value {
          font-size: 0.95rem;
          color: var(--cream);
          font-weight: 300;
        }

        .res-form { display: flex; flex-direction: column; gap: 1rem; }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

        .form-field { display: flex; flex-direction: column; gap: 0.4rem; }

        .form-label {
          font-size: 0.65rem;
          letter-spacing: 0.15em;
          text-transform: uppercase;
          color: rgba(245,240,232,0.55);
        }

        .form-input, .form-select {
          background: rgba(255,255,255,0.07);
          border: 1px solid rgba(184,134,11,0.3);
          color: var(--cream);
          padding: 0.75rem 1rem;
          font-family: 'Jost', sans-serif;
          font-size: 0.9rem;
          font-weight: 300;
          outline: none;
          transition: border-color 0.2s;
          appearance: none;
        }

        .form-input::placeholder { color: rgba(245,240,232,0.3); }

        .form-input:focus, .form-select:focus {
          border-color: var(--gold-light);
        }

        .form-select option { background: var(--brown); }

        .btn-reserve {
          margin-top: 0.5rem;
          background: var(--gold);
          color: var(--brown);
          padding: 1rem 2rem;
          border: none;
          font-family: 'Jost', sans-serif;
          font-size: 0.78rem;
          letter-spacing: 0.15em;
          text-transform: uppercase;
          cursor: pointer;
          font-weight: 500;
          transition: background 0.25s;
        }

        .btn-reserve:hover { background: var(--gold-light); }

        /* FOOTER */
        footer {
          background: #1A1208;
          color: rgba(245,240,232,0.5);
          padding: 3rem 6rem;
          display: grid;
          grid-template-columns: 2fr 1fr 1fr 1fr;
          gap: 3rem;
        }

        .footer-brand {
          font-family: 'Cormorant Garamond', serif;
          font-size: 1.4rem;
          font-weight: 600;
          color: var(--cream);
          margin-bottom: 0.8rem;
        }

        .footer-brand span { color: var(--gold); }

        .footer-tagline {
          font-size: 0.8rem;
          line-height: 1.7;
          color: rgba(245,240,232,0.4);
          font-weight: 300;
          max-width: 220px;
        }

        .footer-heading {
          font-size: 0.65rem;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          color: var(--gold-light);
          margin-bottom: 1.2rem;
        }

        .footer-links { list-style: none; }

        .footer-links li {
          margin-bottom: 0.6rem;
        }

        .footer-links a {
          text-decoration: none;
          font-size: 0.82rem;
          color: rgba(245,240,232,0.45);
          transition: color 0.2s;
          font-weight: 300;
        }

        .footer-links a:hover { color: var(--gold-light); }

        .footer-bottom {
          background: #110D05;
          padding: 1.2rem 6rem;
          display: flex;
          justify-content: space-between;
          align-items: center;
          font-size: 0.72rem;
          color: rgba(245,240,232,0.25);
        }

        

        .hero-tag { animation: fadeUp 0.8s ease both 0.2s; }
        .hero-title { animation: fadeUp 0.8s ease both 0.4s; }
        .hero-desc { animation: fadeUp 0.8s ease both 0.55s; }
        .hero-actions { animation: fadeUp 0.8s ease both 0.7s; }

        /* TOAST */
        .toast {
          position: fixed; bottom: 2rem; right: 2rem;
          background: var(--brown);
          color: var(--cream);
          padding: 1rem 1.5rem;
          font-size: 0.85rem;
          border-left: 3px solid var(--gold);
          transform: translateX(120%);
          transition: transform 0.4s;
          z-index: 200;
        }
        .toast.show { transform: translateX(0); }
    </style>
</head>
<body>

    <!-- NAV -->
    <nav>
        <div class="nav-logo">Trattoria <span>Bella</span></div>
        <ul class="nav-links">
            <li><a href="#menu">Menu</a></li>
            <li><a href="#about">Our Story</a></li>
            <li><a href="#reservation">Reserve</a></li>
        </ul>
        <a href="#reservation" class="nav-reserve">Book a Table</a>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-text">
            <p class="hero-tag">Since 1987 · Florence, Tuscany</p>
            <h1 class="hero-title">
                Where Italy<br>finds its<br><em>truest voice</em>
            </h1>
            <p class="hero-desc">Hand-rolled pasta, wood-fired meats, and recipes carried across generations. Every dish is a letter from home.</p>
            <div class="hero-actions">
                <a href="#menu" class="btn-primary">Explore Menu</a>
                <a href="#reservation" class="btn-secondary">Reserve a Table →</a>
            </div>
        </div>
        <div class="hero-image">
            <div class="hero-image-inner">
                <img class="hero-photo" src="~/img/grandmas-lasagna-hero-02-FT-RECIPE1222-e0117c061ce74af8b2dfae19d08c91a5.webp" alt="Grandma's lasagna"> <!-- IMG SRC -->
            </div>
            <div class="hero-badge">La nostra passione è la cucina</div>
        </div>
    </section>

    <!-- STATS -->
    <div class="about-strip" id="about">
        <div class="about-stat">
            <span class="about-stat-num">37</span>
            <span class="about-stat-label">Years of Tradition</span>
        </div>
        <div class="about-stat">
            <span class="about-stat-num">12</span>
            <span class="about-stat-label">Seasonal Ingredients</span>
        </div>
        <div class="about-stat">
            <span class="about-stat-num">3</span>
            <span class="about-stat-label">Generations of Family Recipes</span>
        </div>
    </div>

    <!-- MENU -->
    <section class="section" id="menu">
        <div class="section-header">
            <div class="section-header-line"></div>
            <div class="section-header-center">
                <p class="section-tag">Il Nostro Menu</p>
                <h2 class="section-title">A Symphony of Flavours</h2>
            </div>
            <div class="section-header-line"></div>
        </div>

        <div class="menu-tabs">
            <button class="menu-tab active" onclick="switchTab(event, 'antipasti')">Antipasti</button>
            <button class="menu-tab" onclick="switchTab(event, 'primi')">Primi Piatti</button>
            <button class="menu-tab" onclick="switchTab(event, 'secondi')">Secondi</button>
            <button class="menu-tab" onclick="switchTab(event, 'dolci')">Dolci</button>
        </div>

        <div class="menu-grid">
            <div class="menu-category active" id="antipasti">
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Burrata con Prosciutto</div>
                        <div class="menu-item-desc">Creamy burrata, San Daniele prosciutto, truffle honey, toasted pine nuts</div>
                    </div>
                    <div class="menu-item-price">R 185</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Carpaccio di Manzo</div>
                        <div class="menu-item-desc">Thin-sliced beef, rocket, capers, Parmesan shavings, lemon oil</div>
                    </div>
                    <div class="menu-item-price">R 165</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Bruschetta al Pomodoro</div>
                        <div class="menu-item-desc">Wood-fired sourdough, vine tomatoes, basil, aged balsamic, garlic</div>
                    </div>
                    <div class="menu-item-price">R 95</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Polpo alla Griglia</div>
                        <div class="menu-item-desc">Grilled octopus, chickpea purée, smoked paprika oil, olives</div>
                    </div>
                    <div class="menu-item-price">R 210</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Zuppa di Pomodoro</div>
                        <div class="menu-item-desc">Slow-roasted tomato soup, basil cream, crispy capers, torn ciabatta</div>
                    </div>
                    <div class="menu-item-price">R 105</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Affettati Misti</div>
                        <div class="menu-item-desc">Selection of cured Italian meats, pickled vegetables, grissini, mostarda</div>
                    </div>
                    <div class="menu-item-price">R 195</div>
                </div>
            </div>

            <div class="menu-category" id="primi" style="display:none">
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Pappardelle al Cinghiale</div>
                        <div class="menu-item-desc">Hand-rolled pappardelle, slow-braised wild boar ragù, rosemary, red wine</div>
                    </div>
                    <div class="menu-item-price">R 225</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Risotto ai Funghi Porcini</div>
                        <div class="menu-item-desc">Carnaroli risotto, porcini mushrooms, Parmesan, white truffle oil</div>
                    </div>
                    <div class="menu-item-price">R 245</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Spaghetti alle Vongole</div>
                        <div class="menu-item-desc">Spaghetti, West Coast clams, white wine, garlic, parsley, chilli</div>
                    </div>
                    <div class="menu-item-price">R 235</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Gnocchi alla Sorrentina</div>
                        <div class="menu-item-desc">Potato gnocchi, San Marzano tomatoes, fresh mozzarella, basil</div>
                    </div>
                    <div class="menu-item-price">R 195</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Tagliatelle al Tartufo</div>
                        <div class="menu-item-desc">Egg tagliatelle, black truffle, butter, aged Parmesan, lemon zest</div>
                    </div>
                    <div class="menu-item-price">R 285</div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-info">
                        <div class="menu-item-name">Lasagne della Nonna</div>
                        <div class="menu-item-desc">Grandmother's recipe, Bolognese, béchamel, handmade pasta sheets</div>
                    </div>
