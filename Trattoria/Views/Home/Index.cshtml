            <div class="mf">
                <label class="ml" for="mEmail">Email address</label>
                <input class="mi" id="mEmail" type="email" placeholder="you@example.com" autocomplete="email">
            </div>
            <div class="mf">
                <label class="ml" for="mPassword">Password</label>
                <input class="mi" id="mPassword" type="password" placeholder="••••••••" autocomplete="current-password">
            </div>
            <div class="modal-error" id="modalError">Please enter both your email and password.</div>
            <button class="modal-submit" id="modalSubmit">Sign In</button>
            <p class="modal-footer">Don't have an account? <a href="#">Create one</a> &nbsp;·&nbsp; <a href="#">Forgot password?</a></p>
        </div>
    </div>

    <script>
        // ─── Helpers ───────────────────────────────────────────────
        function showToast(msg, duration) {
          var t = document.getElementById('toast');
          t.textContent = msg;
          t.classList.add('show');
          setTimeout(function(){ t.classList.remove('show'); }, duration || 4500);
        }

        // ─── Menu tabs ─────────────────────────────────────────────
        document.querySelectorAll('.menu-tab').forEach(function(btn) {
          btn.addEventListener('click', function() {
            document.querySelectorAll('.menu-tab').forEach(function(b){ b.classList.remove('active'); });
            btn.classList.add('active');
            var target = btn.getAttribute('data-tab');
            document.querySelectorAll('.menu-category').forEach(function(c){ c.classList.remove('active'); });
            document.getElementById(target).classList.add('active');
          });
        });

        // ─── Reservation ───────────────────────────────────────────
        document.getElementById('reserveBtn').addEventListener('click', function() {
          showToast("Grazie! Your reservation has been received. We'll confirm by email shortly.");
        });

        // ─── Modal ─────────────────────────────────────────────────
        var modal    = document.getElementById('loginModal');
        var errorEl  = document.getElementById('modalError');

        function openModal() {
          modal.classList.add('open');
          document.body.classList.add('no-scroll');
          setTimeout(function(){ document.getElementById('mEmail').focus(); }, 60);
        }

        function closeModal() {
          modal.classList.remove('open');
          document.body.classList.remove('no-scroll');
          errorEl.classList.remove('visible');
        }

        document.getElementById('openLoginBtn').addEventListener('click', openModal);
        document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
        modal.addEventListener('click', function(e) {
          if (e.target === modal) closeModal();
        });
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
        });

        document.getElementById('modalSubmit').addEventListener('click', function() {
          var email = document.getElementById('mEmail').value.trim();
          var pass  = document.getElementById('mPassword').value;
          if (!email || !pass) {
            errorEl.classList.add('visible');
            return;
          }
          errorEl.classList.remove('visible');
          closeModal();
          showToast('Benvenuto! You are now signed in.', 4000);
        });

        ['mEmail','mPassword'].forEach(function(id) {
          document.getElementById(id).addEventListener('input', function() {
            errorEl.classList.remove('visible');
          });
        });
        ['mEmail','mPassword'].forEach(function(id) {
          document.getElementById(id).addEventListener('keydown', function(e) {
            if (e.key === 'Enter') document.getElementById('modalSubmit').click();
          });
        });
    </script>
