@model Trattoria.ViewModels.ReceptionistHomeViewModel
@{
    ViewData["Title"] = "Receptionist Dashboard · Trattoria Bella";
    Layout = null; // standalone page; swap to _Layout if you have a shared shell
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --cream: #F5F0E8;
            --warm-white: #FAF7F2;
            --gold: #B8860B;
            --gold-light: #D4A820;
            --brown: #3D2B1F;
            --brown-mid: #6B4226;
            --red: #8B1A1A;
            --text: #2A1F17;
            --text-muted: #7A6558;
            --shadow: 0 8px 24px rgba(0,0,0,0.08);
            --radius: 14px;
        }

        body {
            font-family: 'Jost', sans-serif;
            background: #f2ede6;
            color: var(--text);
            padding: 2rem;
            min-height: 100vh;
        }

        .receptionist-dashboard {
            max-width: 1440px;
            margin: 0 auto;
        }

        /* Header */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .brand {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 600;
            color: var(--brown);
        }

            .brand span {
                color: var(--gold);
            }

        .receptionist-badge {
            background: var(--brown);
            color: var(--cream);
            padding: 0.4rem 1.4rem;
            border-radius: 40px;
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            font-weight: 400;
        }

        .header-actions {
            display: flex;
            gap: 0.8rem;
            align-items: center;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 0.5rem 1.4rem;
            border-radius: 40px;
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Jost', sans-serif;
        }

            .btn-outline:hover {
                background: var(--gold);
                color: white;
            }

        .btn-primary-sm {
            background: var(--red);
            border: none;
            color: white;
            padding: 0.5rem 1.6rem;
            border-radius: 40px;
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Jost', sans-serif;
            text-decoration: none;
            display: inline-block;
        }

            .btn-primary-sm:hover {
                background: var(--brown);
            }

        /* Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1.2rem;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: var(--warm-white);
            padding: 1.2rem 1.5rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border-left: 4px solid var(--gold);
        }

            .stat-card .label {
                font-size: 0.65rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--text-muted);
                font-weight: 400;
            }

            .stat-card .value {
                font-family: 'Cormorant Garamond', serif;
                font-size: 2rem;
                font-weight: 400;
                color: var(--brown);
                line-height: 1.2;
            }

            .stat-card .sub {
                font-size: 0.7rem;
                color: var(--text-muted);
                font-weight: 300;
            }

        /* Grid */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 2rem;
            align-items: start;
        }

        @@media (max-width: 900px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Panel */
        .panel {
            background: var(--warm-white);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 1.8rem;
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.2rem;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

            .panel-header h3 {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.4rem;
                font-weight: 400;
                color: var(--brown);
            }

            .panel-header .badge {
                font-size: 0.65rem;
                background: var(--cream);
                padding: 0.2rem 1rem;
                border-radius: 40px;
                color: var(--text-muted);
            }

        /* Reservation list */
        .reservation-list {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            max-height: 420px;
            overflow-y: auto;
            padding-right: 0.3rem;
        }

            .reservation-list::-webkit-scrollbar {
                width: 4px;
            }

            .reservation-list::-webkit-scrollbar-thumb {
                background: var(--gold-light);
                border-radius: 10px;
            }

        .reservation-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.7rem 1rem;
            background: white;
            border-radius: 10px;
            border-left: 4px solid var(--gold);
            transition: 0.15s;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

            .reservation-card:hover {
                box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            }

        .res-info {
            display: flex;
            flex-direction: column;
            flex: 1;
            min-width: 120px;
        }

        .res-name {
            font-weight: 500;
            font-size: 0.9rem;
        }

        .res-detail {
            font-size: 0.7rem;
            color: var(--text-muted);
        }

        .res-meta {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .res-time {
            font-weight: 500;
            font-size: 0.8rem;
            color: var(--brown);
            background: var(--cream);
            padding: 0.15rem 0.7rem;
            border-radius: 30px;
        }

        .res-status {
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            padding: 0.15rem 0.7rem;
            border-radius: 30px;
        }

            .res-status.confirmed {
                background: #dce8d8;
                color: #1e4a1e;
            }

            .res-status.seated {
                background: #f5e0c8;
                color: #a0672a;
            }

            .res-status.waiting {
                background: #f0d8d8;
                color: #8b1a1a;
            }

            .res-status.completed {
                background: #e8e0d8;
                color: var(--text-muted);
            }

        .res-actions {
            display: flex;
            gap: 0.4rem;
        }

            .res-actions button {
                border: none;
                border-radius: 30px;
                padding: 0.2rem 0.8rem;
                font-size: 0.6rem;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                cursor: pointer;
                font-family: 'Jost', sans-serif;
                transition: 0.15s;
            }

        .btn-seat {
            background: var(--gold);
            color: white;
        }

            .btn-seat:hover {
                background: var(--gold-light);
            }

        .btn-complete {
            background: #2a5a2a;
            color: white;
        }

            .btn-complete:hover {
                background: #1e421e;
            }

        .btn-cancel-res {
            background: #e8d8d8;
            color: #6a3a3a;
        }

            .btn-cancel-res:hover {
                background: #dcc8c8;
            }

        /* Table map */
        .table-grid-mini {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.6rem;
            margin-top: 0.5rem;
        }

        .table-mini {
            padding: 0.6rem 0.3rem;
            text-align: center;
            background: white;
            border-radius: 8px;
            border: 1px solid rgba(184,134,11,0.12);
            font-size: 0.7rem;
            transition: 0.15s;
        }

            .table-mini .t-nr {
                font-weight: 600;
                font-size: 0.8rem;
                color: var(--brown);
            }

            .table-mini .t-cap {
                font-size: 0.55rem;
                color: var(--text-muted);
            }

            .table-mini .t-type {
                font-size: 0.55rem;
                color: var(--text-muted);
            }

            .table-mini .t-status {
                font-size: 0.55rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }

            .table-mini.available {
                border-color: #b8d0b8;
                background: #f2f8f2;
            }

                .table-mini.available .t-status {
                    color: #2a5a2a;
                }

            .table-mini.occupied {
                border-color: #d4b8a0;
                background: #f8f0e8;
            }

                .table-mini.occupied .t-status {
                    color: #a0672a;
                }

        /* Quick actions */
        .quick-actions {
            display: flex;
            gap: 0.6rem;
            margin-top: 1.2rem;
            flex-wrap: wrap;
            align-items: flex-end;
        }

            .quick-actions button {
                padding: 0.7rem 1rem;
                border: none;
                border-radius: 40px;
                font-family: 'Jost', sans-serif;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                cursor: pointer;
                transition: 0.2s;
            }

        .btn-walkin {
            background: var(--gold);
            color: white;
        }

            .btn-walkin:hover {
                background: var(--gold-light);
            }

        .walkin-guests {
            width: 60px;
            padding: 0.5rem 0.7rem;
            border: 1px solid var(--gold);
            border-radius: 40px;
            font-size: 0.75rem;
            font-family: 'Jost', sans-serif;
            text-align: center;
            background: white;
            color: var(--text);
        }

        /* Toast */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--brown);
            color: var(--cream);
            padding: 0.8rem 1.6rem;
            border-radius: 40px;
            font-size: 0.85rem;
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
            transform: translateX(130%);
            transition: transform 0.35s ease;
            z-index: 999;
        }

            .toast.show {
                transform: translateX(0);
            }

        /* Legend */
        .legend {
            margin-top: 1.5rem;
            border-top: 1px solid rgba(184,134,11,0.12);
            padding-top: 1rem;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            font-size: 0.7rem;
            color: var(--text-muted);
        }

        /* Empty state */
        .empty-state {
            color: var(--text-muted);
            font-weight: 300;
            padding: 1rem 0;
            text-align: center;
        }

        /* Modal */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(61,43,31,0.45);
            backdrop-filter: blur(3px);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }

            .modal-overlay.open {
                opacity: 1;
                pointer-events: all;
            }

        .modal {
            background: var(--warm-white);
            border-radius: var(--radius);
            box-shadow: 0 20px 60px rgba(0,0,0,0.18);
            padding: 2rem 2.2rem;
            width: 100%;
            max-width: 500px;
            transform: translateY(20px);
            transition: transform 0.25s ease;
        }

        .modal-overlay.open .modal {
            transform: translateY(0);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.6rem;
        }

            .modal-header h3 {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.5rem;
                font-weight: 400;
                color: var(--brown);
            }

        .modal-close {
            background: none;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            color: var(--text-muted);
            line-height: 1;
            padding: 0.2rem;
        }

            .modal-close:hover {
                color: var(--red);
            }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }

            .form-group.full {
                grid-column: 1 / -1;
            }

            .form-group label {
                font-size: 0.65rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--text-muted);
                font-weight: 400;
            }

            .form-group input, .form-group select {
                border: 1px solid rgba(184,134,11,0.25);
                border-radius: 8px;
                padding: 0.55rem 0.8rem;
                font-family: 'Jost', sans-serif;
                font-size: 0.85rem;
                color: var(--text);
                background: white;
                outline: none;
                transition: border-color 0.15s;
                width: 100%;
            }

                .form-group input:focus, .form-group select:focus {
                    border-color: var(--gold);
                }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 0.7rem;
            margin-top: 1.6rem;
        }

        .btn-modal-cancel {
            background: var(--cream);
            border: none;
            color: var(--text-muted);
            padding: 0.6rem 1.4rem;
            border-radius: 40px;
            font-family: 'Jost', sans-serif;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-modal-cancel:hover {
                background: #e8e0d8;
            }

        .btn-modal-submit {
            background: var(--red);
            border: none;
            color: white;
            padding: 0.6rem 1.8rem;
            border-radius: 40px;
            font-family: 'Jost', sans-serif;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-modal-submit:hover {
                background: var(--brown);
            }
    </style>
</head>
<body>

    <div class="receptionist-dashboard">

        <!-- ── HEADER ────────────────────────────────────────────── -->
        <header class="dashboard-header">
            <div class="header-left">
                <div class="brand">Trattoria <span>Bella</span></div>
                <span class="receptionist-badge">📋 Receptionist · @Model.ReceptionistName</span>
            </div>
            <div class="header-actions">
                <a asp-action="ReceptionistHome" class="btn-outline">🔄 Refresh</a>
                <button type="button" class="btn-primary-sm" onclick="openModal()">➕ Add reservation</button>
            </div>
        </header>

        <!-- ── STATS ─────────────────────────────────────────────── -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="label">Total reservations</div>
                <div class="value">@Model.TotalReservations</div>
            </div>
            <div class="stat-card">
                <div class="label">Seated</div>
                <div class="value">@Model.SeatedCount</div>
            </div>
            <div class="stat-card">
                <div class="label">Waiting / Confirmed</div>
                <div class="value">@Model.WaitingOrConfirmedCount</div>
            </div>
            <div class="stat-card">
                <div class="label">Available tables</div>
                <div class="value">@Model.AvailableTablesCount</div>
                <div class="sub">@Model.OccupiedTablesCount occupied</div>
            </div>
        </div>

        <!-- ── MAIN GRID ──────────────────────────────────────────── -->
        <div class="dashboard-grid">

            <!-- LEFT: Reservations panel -->
            <div class="panel">
                <div class="panel-header">
                    <h3>📅 Reservations</h3>
                    <span class="badge">@Model.TotalReservations</span>
                </div>

                <div class="reservation-list">
                    @if (!Model.Reservations.Any())
                    {
                        <div class="empty-state">No reservations for today.</div>
                    }
                    else
                    {
                        foreach (var r in Model.Reservations)
                        {
                            <div class="reservation-card">
                                <div class="res-info">
                                    <span class="res-name">@r.GuestName</span>
                                    <span class="res-detail">
                                        @r.GuestCapacity guests &middot; Table @r.TableID (@r.TableType)
                                        @if (!string.IsNullOrEmpty(r.ContactPhone) && r.ContactPhone != "—")
                                        {
                                            <span>&middot; @r.ContactPhone</span>
                                        }
                                    </span>
                                </div>
                                <div class="res-meta">
                                    <span class="res-time">@r.ReservationDate.ToString("HH:mm")</span>
                                    <span class="res-status @r.StatusCssClass">@r.StatusLabel</span>

                                    <div class="res-actions">
                                        <!-- Seat -->
                                        @if (r.CanSeat)
                                        {
                                            <form method="post" asp-action="SeatReservation" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="reservationID" value="@r.ReservationID" />
                                                <button type="submit" class="btn-seat">Seat</button>
                                            </form>
                                        }

                                        <!-- Complete -->
                                        @if (r.CanComplete)
                                        {
                                            <form method="post" asp-action="CompleteReservation" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="reservationID" value="@r.ReservationID" />
                                                <button type="submit" class="btn-complete">Done</button>
                                            </form>
                                        }

                                        <!-- Cancel -->
                                        @if (r.CanCancel)
                                        {
                                            <form method="post" asp-action="CancelReservation" style="display:inline;"
                                                  onsubmit="return confirm('Cancel reservation for @r.GuestName?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="reservationID" value="@r.ReservationID" />
                                                <button type="submit" class="btn-cancel-res">✕</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Walk-in quick action -->
                <form method="post" asp-action="WalkIn" class="quick-actions">
                    @Html.AntiForgeryToken()
                    <label for="walkinGuests" style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.08em; align-self:center;">Guests</label>
                    <input id="walkinGuests" class="walkin-guests" type="number" name="guests" value="2" min="1" max="20" />
                    <button type="submit" class="btn-walkin">🚶 Walk-in guest</button>
                </form>
            </div>

            <!-- RIGHT: Table Map panel -->
            <div class="panel">
                <div class="panel-header">
                    <h3>🪑 Table Map</h3>
                    <span class="badge">@Model.Tables.Count tables</span>
                </div>

                <div class="table-grid-mini">
                    @foreach (var t in Model.Tables)
                    {
                        var tClass = t.IsAvailable ? "available" : "occupied";
                        var tLabel = t.IsAvailable ? "🟢 Avail" : "🟠 Occupied";

                        <div class="table-mini @tClass">
                            <div class="t-nr">#@t.TableID</div>
                            <div class="t-type">@t.Type</div>
                            <div class="t-cap">Cap. @t.Capacity</div>
                            <div class="t-status">@tLabel</div>
                        </div>
                    }
                </div>

                <div class="legend">
                    <span>🟢 Available</span>
                    <span>🟠 Occupied</span>
                </div>
            </div>

        </div>
    </div>

    <!-- ADD RESERVATION MODAL -->
    <div class="modal-overlay" id="addResModal">
        <div class="modal">
            <div class="modal-header">
                <h3>➕ New Reservation</h3>
                <button type="button" class="modal-close" onclick="closeModal()">✕</button>
            </div>

            <form method="post" asp-action="AddReservation">
                @Html.AntiForgeryToken()
                <div class="form-grid">

                    <div class="form-group">
                        <label for="resName">First Name</label>
                        <input id="resName" type="text" name="name" placeholder="e.g. Marco" required />
                    </div>

                    <div class="form-group">
                        <label for="resSurname">Surname</label>
                        <input id="resSurname" type="text" name="surname" placeholder="e.g. Rossi" required />
                    </div>

                    <div class="form-group">
                        <label for="resPhone">Contact Phone</label>
                        <input id="resPhone" type="tel" name="contactPhone" placeholder="+27 82 000 0000" />
                    </div>

                    <div class="form-group">
                        <label for="resEmail">Email</label>
                        <input id="resEmail" type="email" name="email" placeholder="guest@email.com" />
                    </div>

                    <div class="form-group">
                        <label for="resDate">Date &amp; Time</label>
                        <input id="resDate" type="datetime-local" name="reservationDate" required
                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    <div class="form-group">
                        <label for="resCapacity">Guests</label>
                        <input id="resCapacity" type="number" name="capacity" min="1" max="20" value="2" required />
                    </div>

                    <div class="form-group full">
                        <label for="resTable">Table</label>
                        <select id="resTable" name="tableID" required>
                            <option value="">— Select a table —</option>
                            @foreach (var t in Model.Tables.Where(t => t.IsAvailable))
                            {
                                <option value="@t.TableID">Table #@t.TableID — @t.Type (Cap. @t.Capacity)</option>
                            }
                        </select>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-modal-cancel" onclick="closeModal()">Cancel</button>
                    <button type="submit" class="btn-modal-submit">Confirm Reservation</button>
                </div>
            </form>
        </div>
    </div>

    <!-- TOAST -->
    <div class="toast" id="toast"></div>

    @if (TempData["ToastMessage"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var toast = document.getElementById('toast');
                toast.textContent = '@Html.Raw(TempData["ToastMessage"])';
                toast.classList.add('show');
                setTimeout(function () { toast.classList.remove('show'); }, 3000);
            });
        </script>
    }

    <script>
        function openModal()  { document.getElementById('addResModal').classList.add('open'); }
        function closeModal() { document.getElementById('addResModal').classList.remove('open'); }

        // Close when clicking the dark overlay outside the modal box
        document.getElementById('addResModal').addEventListener('click', function (e) {
            if (e.target === this) closeModal();
        });

        // Close on Escape key
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeModal();
        });
    </script>

</body>
</html>
